<?php

/**
 * @file
 * Primary module hooks for booking module.
 */

/**
 * Implements hook_mail().
 */
function booking_mail($key, &$message, $params) {
  $message['from'] = \Drupal::config('system.site')->get('mail');
  $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';
  $message['subject'] = $params['subject'] ?? '';
  $message['body'][] = $params['body'] ?? '';
}

/**
 * Implements hook_entity_presave().
 */
function booking_entity_presave(Drupal\Core\Entity\EntityInterface $entity) {
  if ($entity->getEntityTypeId() === 'booking' && !$entity->isNew()) {
    /** @var \Drupal\booking\Entity\BookingEntity $entity */
    $original = $entity->original;
    if ($original && $entity->get('booking_status')->value !== $original->get('booking_status')->value) {
      $mail_service = \Drupal::service('booking.mail_service');
      $mail_service->sendStatusNotification($entity);
      $mail_service->sendAdviserNotification($entity, 'status_change');
    }
  }
}
/**
 * Implements hook_theme().
 */
function booking_theme() {
  return [
    'booking_card' => [
      'variables' => [
        'title' => NULL,
        'address' => NULL,
        'phone' => NULL,
        'email' => NULL,
        'hours' => NULL,
        'description' => NULL,
      ],
    ],
    'booking_email_status' => [
      'variables' => [
        'reference' => NULL,
        'status_label' => NULL,
        'customer_name' => NULL,
      ],
    ],
    'booking_email_access_code' => [
      'variables' => [
        'reference' => NULL,
        'code' => NULL,
      ],
    ],
    'booking_email_confirmation' => [
      'variables' => [
        'reference' => NULL,
        'customer_name' => NULL,
        'booking_date' => NULL,
        'agency_name' => NULL,
      ],
    ],
    'booking_email_adviser' => [
      'variables' => [
        'reference' => NULL,
        'customer_name' => NULL,
        'booking_date' => NULL,
        'status_label' => NULL,
        'type' => NULL,
      ],
    ],
  ];
}
