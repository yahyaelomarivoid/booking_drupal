<?php

/**
 * @file
 * Primary module hooks for booking module.
 */

/**
 * Implements hook_mail().
 */
function booking_mail($key, &$message, $params)
{
  $message['from'] = \Drupal::config('system.site')->get('mail');
  $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';
  $message['subject'] = $params['subject'] ?? '';
  $message['body'][] = $params['body'] ?? '';
}

/**
 * Implements hook_entity_presave().
 */
function booking_entity_presave(Drupal\Core\Entity\EntityInterface $entity)
{
  if ($entity->getEntityTypeId() === 'booking' && !$entity->isNew()) {
    /** @var \Drupal\booking\Entity\BookingEntity $entity */
    $original = $entity->original;
    if ($original && $entity->get('booking_status')->value !== $original->get('booking_status')->value) {
      $mail_service = \Drupal::service('booking.mail_service');
      $mail_service->sendStatusNotification($entity);
      $mail_service->sendAdviserNotification($entity, 'status_change');
    }
  }
}
/**
 * Implements hook_theme().
 */
function booking_theme()
{
  return [
    'booking_card' => [
      'variables' => [
        'title' => NULL,
        'address' => NULL,
        'phone' => NULL,
        'email' => NULL,
        'hours' => NULL,
        'description' => NULL,
      ],
    ],
    'booking_email_status' => [
      'variables' => [
        'reference' => NULL,
        'status_label' => NULL,
        'customer_name' => NULL,
      ],
    ],
    'booking_email_access_code' => [
      'variables' => [
        'reference' => NULL,
        'code' => NULL,
      ],
    ],
    'booking_email_confirmation' => [
      'variables' => [
        'reference' => NULL,
        'customer_name' => NULL,
        'booking_date' => NULL,
        'agency_name' => NULL,
      ],
    ],
    'booking_email_adviser' => [
      'variables' => [
        'reference' => NULL,
        'customer_name' => NULL,
        'booking_date' => NULL,
        'status_label' => NULL,
        'type' => NULL,
      ],
    ],
  ];
}

/**
 * Implements hook_form_alter().
 */
function booking_form_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id)
{
  // Target the user profile edit forms (e.g., user_form, user_register_form)
  if (in_array($form_id, ['user_form', 'user_register_form'])) {
    $form['#validate'][] = 'booking_user_form_validate';
  }
}

/**
 * Custom validation callback for the user form.
 */
function booking_user_form_validate(&$form, \Drupal\Core\Form\FormStateInterface $form_state)
{
  $working_hours = $form_state->getValue('field_working_hours');

  // Drupal fields are often stored as nested arrays
  // (because a field could theoretically have multiple values)
  if (!empty($working_hours[0]['value'])) {
    $value = $working_hours[0]['value'];

    $pattern = '/^((0[0-9]|1[0-9]|2[0-3]):[0-5][0-9]-(0[0-9]|1[0-9]|2[0-3]):[0-5][0-9])(,\s*(0[0-9]|1[0-9]|2[0-3]):[0-5][0-9]-(0[0-9]|1[0-9]|2[0-3]):[0-5][0-9])*$/';

    if (!preg_match($pattern, trim($value))) {
      $form_state->setErrorByName('field_working_hours', t('Working hours must be in the format HH:MM-HH:MM (e.g., 09:00-17:00). Multiple ranges can be separated by commas (e.g., 09:00-12:00, 14:00-18:00).'));
    }
  }
}
